{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "width": 500,
  "height": 300,

  "signals": [],

  "data": [],

  "scales": [
    {
      "name": "xscale",
      "type": "band",
      "domain": {"data": "__DATASET__", "field": "__X_FIELD__"},
      "range": "width",
      "padding": 0.2
    },
    {
      "name": "yscale",
      "type": "linear",
      "domain": {"data": "__DATASET__", "field": "__Y_FIELD__"},
      "nice": true,
      "range": "height"
    }
  ],

  "axes": [
    {"orient": "bottom", "scale": "xscale", "title": "__X_FIELD__"},
    {"orient": "left", "scale": "yscale", "title": "__Y_FIELD__"}
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "__DATASET__"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "__X_FIELD__"},
          "width": {"scale": "xscale", "band": 1},
          "y": {"scale": "yscale", "field": "__Y_FIELD__"},
          "y2": {"scale": "yscale", "value": 0},
          "fill": {"value": "#7bbe1f"}
        },
        "hover": {
          "fill": {"value": "#ff5722"}
        },
        "update": {
          "fill": {"value": "#7bbe1f"}
        }
      }
    },

    {
      "type": "line",
      "from": {"data": "__DATASET__"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "__X_FIELD__", "band": 0.5},
          "y": {"scale": "yscale", "field": "__Y_FIELD__"},
          "stroke": {"value": "rgb(0, 140, 150)"},
          "strokeWidth": {"value": 3}
        }
      }
    },
    {
      "type": "symbol",
      "from": {"data": "__DATASET__"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "__X_FIELD__", "band": 0.5},
          "y": {"scale": "yscale", "field": "__Y_FIELD__"},
          "size": {"value": 140},
          "fill": {"value": "rgb(255, 193, 7)"},
          "stroke": {"value": "rgb(0, 0, 0)"},
          "strokeWidth": {"value": 1.5}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "__DATASET__"},
      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "__X_FIELD__", "band": 0.5},
          "y": {"scale": "yscale", "field": "__Y_FIELD__"},
          "dy": {"value": -14},
          "text": {"field": "__Y_FIELD__"},
          "align": {"value": "center"},
          "fill": {"value": "rgb(33, 33, 33)"},
          "fontSize": {"value": 12}
        }
      }
    }
  ]
}
