{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Generated by GUI4Vega wizard",
  "width": 500,
  "height": 300,

  "data": [
    {
      "name": "pie_data",
      "source": "__DATASET__",
      "transform": [
        {
          "type": "pie",
          "field": "__ID_FIELD__"
        }
      ]
    }
  ],

  "signals": [],

  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": { "data": "pie_data", "field": "__VALUE_FIELD__" },
      "range": { "scheme": "category20" }
    }
  ],

  "marks": [
    {
      "type": "arc",
      "from": { "data": "pie_data" },
      "encode": {
        "enter": {
          "fill": { "scale": "color", "field": "__VALUE_FIELD__" },
          "x": { "signal": "width / 2" },
          "y": { "signal": "height / 2" }
        },
        "update": {
          "startAngle": { "field": "startAngle" },
          "endAngle": { "field": "endAngle" },
          "innerRadius": { "value": 0 },
          "outerRadius": { "signal": "min(width, height) / 2" }
        }
      }
    }
  ],

  "legends": [
    { "fill": "color", "title": "__VALUE_FIELD__" }
  ]
}

